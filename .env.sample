# Flow API - Configurações para acesso à API Flow
FLOW_BASE_URL=https://flow.ciandt.com
FLOW_CLIENT_ID=seu-client-id
FLOW_CLIENT_SECRET=seu-client-secret
FLOW_APP_TO_ACCESS=llm-api
FLOW_TENANT=seu-tenant

# Configurações do modelo - OpenAI
FLOW_DEFAULT_MODEL=gpt-4o-mini
FLOW_MAX_TOKENS=4096

# Configurações de UI
FLOW_SHOW_TOKEN_COUNT=true
FLOW_ENABLE_STREAMING=false

# Configurações de memória (em segundos)
FLOW_CONTEXT_TTL=3600
